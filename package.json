{
  "name": "nodejs-backend-demo",
  "version": "1.0.0",
  "description": "- app.js - Express app setup (NO listen here) - server.js - Entry point: starts HTTP + WebSocket",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "start": "node --env-file=.env src/server.js",  // native .env loading
    "dev": "node --env-file=.env --watch src/server.js", // Node 18.11+ built-in watch
    "test": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:coverage": "node --env-file=.env.test --experimental-vm-modules node_modules/.bin/jest --coverage",
    "migrate": "prisma migrate dev",
    "migrate:deploy":"p risma migrate deploy",
    "migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "lint": "eslint src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenHampton/nodejs-backend-demo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/BenHampton/nodejs-backend-demo/issues"
  },
  "homepage": "https://github.com/BenHampton/nodejs-backend-demo#readme",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@scalar/express-api-reference": "^0.9.20",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  }
}
